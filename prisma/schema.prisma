generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  userId    String   @unique @map("user_id")
  name      String
  dept      String?
  role      String?
  status    String?  @default("재직")
  email     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_tbl")
}

model ScheduleEvent {
  id        BigInt   @id @default(autoincrement())
  title     String   @db.VarChar(200)
  startDt   DateTime @map("start_dt")
  endDt     DateTime? @map("end_dt")
  allDay    Boolean  @default(false) @map("all_day")
  category  String?  @db.VarChar(50)
  color     String?  @db.VarChar(16)
  memo      String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  evType    String   @default("HUMAN") @map("ev_type") @db.VarChar(45)

  @@index([startDt, endDt], map: "idx_schedule_range")
  @@index([startDt, endDt, evType], map: "idx_schedule_event_range")
  @@map("schedule_event")
}
